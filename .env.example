# ── Threat Intel Agent — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your keys.
# NEVER commit .env to Git. It is already in .gitignore.

# Groq — free LLM inference (llama-3.3-70b-versatile)
# Sign up: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# VirusTotal — IP/domain/hash reputation
# Sign up: https://www.virustotal.com/gui/join-us
# Free tier: 500 lookups/day, 4 requests/min
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Shodan — open ports, services, CVEs on IPs
# Sign up: https://account.shodan.io/register
# Free tier: limited to host lookup endpoint
SHODAN_API_KEY=your_shodan_api_key_here

# AbuseIPDB — community IP abuse reports
# Sign up: https://www.abuseipdb.com/register
# Free tier: 1000 checks/day
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
