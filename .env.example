# ── Threat Intel Agent — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your keys.
# NEVER commit .env to Git. It is already in .gitignore.

# ── LLM Provider ─────────────────────────────────────────────────────────
# Groq (free tier: llama-3.3-70b-versatile): https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Threat Intelligence Enrichment ───────────────────────────────────────
# VirusTotal (free: 500/day, 4/min): https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Shodan (free: limited host lookup): https://account.shodan.io/register
SHODAN_API_KEY=your_shodan_api_key_here

# AbuseIPDB (free: 1000/day): https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# AlienVault OTX (free: 1M/month): https://otx.alienvault.com
OTX_API_KEY=your_otx_api_key_here

# ── TIP Integrations (all optional) ──────────────────────────────────────
# MISP_URL=https://misp.local
# MISP_API_KEY=your_misp_key
# OPENCTI_URL=https://opencti.local
# OPENCTI_API_KEY=your_opencti_key
# THEHIVE_URL=https://thehive.local
# THEHIVE_API_KEY=your_thehive_key

# ── Notifications (all optional) ─────────────────────────────────────────
# Slack: https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Microsoft Teams (incoming webhook)
# TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/...

# SMTP / Email
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=you@gmail.com
# SMTP_TO=you@gmail.com

# ── Server (all optional, shown with defaults) ───────────────────────────
# TIA_HOST=127.0.0.1
# TIA_PORT=8000
# TIA_API_KEY=
# TIA_DISABLE_AUTH=false
# TIA_RELOAD=false
# CORS_ORIGINS=http://localhost:5173,http://localhost:8000
# RATE_LIMIT_REQUESTS=60
# RATE_LIMIT_WINDOW_SECONDS=60
# LLM_MODEL=llama-3.3-70b-versatile
