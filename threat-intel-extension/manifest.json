{
  "manifest_version": 3,
  "name": "Threat Intel Agent",
  "version": "1.0.0",
  "description": "Real-time IOC detection, investigation, and threat intelligence in your browser sidebar.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "notifications",
    "alarms",
    "sidePanel",
    "clipboardRead"
  ],
  "host_permissions": [
    "http://localhost:8000"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+I" },
      "description": "Open Threat Intel sidebar"
    },
    "investigate-selection": {
      "suggested_key": { "default": "Ctrl+Shift+T" },
      "description": "Investigate selected IOC"
    },
    "scan-page": {
      "suggested_key": { "default": "Ctrl+Shift+S" },
      "description": "Scan page for IOCs"
    }
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Threat Intel Agent",
    "default_icon": {
      "16": "icons/brand-icon.png",
      "32": "icons/brand-icon.png",
      "48": "icons/brand-icon.png",
      "128": "icons/brand-icon.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/brand-icon.png",
    "32": "icons/brand-icon.png",
    "48": "icons/brand-icon.png",
    "128": "icons/brand-icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/brand-icon.png", "styles.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src http://localhost:8000"
  }
}